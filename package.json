{
  "name": "SnapNotes",
  "version": "1.0.0",
  "description": "A note-taking application with AI-powered image analysis",
  "main": "index.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend",
    "start": "npm run start --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "android:sync": "npx cap sync android",
    "android:build": "npx cap sync android && cd android && ./gradlew assembleRelease",
    "android:build:debug": "npx cap sync android && cd android && ./gradlew assembleDebug",
    "android:open": "npx cap open android",
    "android:run": "npx cap run android",
    "test": "echo 'Error: no test specified' && exit 1"
  },
  "author": "Miraziz574",
  "license": "ISC",
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "@capacitor/core": "^5.5.1",
    "@capacitor/cli": "^5.5.1",
    "@capacitor/android": "^5.5.1",
    "@capacitor/camera": "^5.0.9",
    "@capacitor/filesystem": "^5.1.4",
    "@capacitor/local-notifications": "^5.0.7",
    "@capacitor/splash-screen": "^5.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.0"
  }
}
