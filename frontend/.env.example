# API base URL for production environments (Android, iOS, PWA on a device).
# When running `npm run dev` locally, leave this unset so the Vite proxy handles
# requests to /api and /uploads automatically.
# For production, set this to your hosted backend URL, e.g.:
# VITE_API_URL=https://your-backend.example.com
VITE_API_URL=http://localhost:3001
